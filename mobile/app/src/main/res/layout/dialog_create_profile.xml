<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Create New Profile"
        android:textSize="22sp"
        android:textStyle="bold" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edit_text_profile_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Profile Name (e.g., Morning Plan)" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edit_text_plant_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Plant Name (e.g., Tomato)" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Threshold: Moisture (0-100) -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edit_text_moisture_threshold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Moisture Threshold (0-100)"
            android:inputType="number" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Threshold: Temperature (-100 .. 100) -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edit_text_temp_threshold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Temperature Threshold (-100..100)"
            android:inputType="numberSigned" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Threshold: Humidity (0-100) -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edit_text_humidity_threshold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Humidity Threshold (0-100)"
            android:inputType="number" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Threshold: Light (0-100) -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edit_text_light_threshold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Light Threshold (0-100)"
            android:inputType="number" />
    </com.google.android.material.textfield.TextInputLayout>

</LinearLayout>
